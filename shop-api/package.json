{
  "name": "api",
  "version": "1.0.50",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "bun run --watch src/server.ts",
    "lint": "bunx biome check --write",
    "prepare": "husky",
    "build": "bun build --compile --external pg  --minify-whitespace --minify-syntax--target bun --outfile server src/index.ts",
    "set:permission": "chmod +x ./server",
    "start": "NODE_ENV=production && ./server",
    "db:migrate": "bun prisma migrate dev --name",
    "db:migrate-reset": "bun prisma migrate reset",
    "db:push": "bun prisma db push",
    "db:generate": "bun prisma generate",
    "db:studio": "bun prisma studio"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.0",
    "@elysiajs/jwt": "^1.4.0",
    "@elysiajs/openapi": "^1.4.11",
    "@elysiajs/opentelemetry": "^1.4.8",
    "@elysiajs/server-timing": "^1.4.0",
    "@prisma/adapter-pg": "^7.0.1",
    "@prisma/client": "^7.0.1",
    "arktype": "^2.1.27",
    "consola": "^3.4.2",
    "elysia": "latest",
    "pg": "^8.16.3",
    "prismabox": "^1.1.25"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.8",
    "@types/pg": "^8.15.6",
    "bun-types": "latest",
    "husky": "^9.1.7",
    "prisma": "^7.0.1"
  },
  "module": "src/index.js"
}
